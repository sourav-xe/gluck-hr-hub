MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/hrms?retryWrites=true&w=majority"
PORT=3001
JWT_SECRET="change-this-to-a-long-random-string"
VITE_API_URL="http://localhost:3001"
# Google Chat incoming webhook (used by backend relay)
GCHAT_WEBHOOK_URL="https://chat.googleapis.com/v1/spaces/SPACE_ID/messages?key=YOUR_KEY&token=YOUR_TOKEN"
# Optional production CORS (comma-separated). Leave unset to mirror dev (reflect request origin).
# FRONTEND_ORIGIN="https://hr.yourcompany.com"

# Optional: AI-assisted placeholder naming (document automation). Without this, heuristics are used.
# OPENAI_API_KEY="sk-..."
# OPENAI_MODEL="gpt-4o-mini"

# Faithful PDF from DOCX (watermarks, logos, layout). Install LibreOffice, restart API — or set explicit path:
# LIBREOFFICE_PATH="C:\\Program Files\\LibreOffice\\program\\soffice.exe"
# (Alias: SOFFICE_PATH)
# If PDFs are plain text but LibreOffice is installed, try (Windows headless quirk):
# LIBREOFFICE_SKIP_ISOLATED_PROFILE=1

# Email (SMTP via Gmail). Use a Gmail App Password (not your regular password).
# To create an App Password: Google Account → Security → 2-Step Verification → App Passwords
# EMAIL_FROM="youremail@gmail.com"
# EMAIL_PASS="xxxx xxxx xxxx xxxx"
